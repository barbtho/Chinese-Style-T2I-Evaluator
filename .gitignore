# =========================
# 1. Python 缓存与虚拟环境
# =========================
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.env

# =========================
# 2. IDE 配置文件
# =========================
.idea/
.vscode/
*.swp

# =========================
# 3. AI 模型权重缓存 (防超大文件报错)
# =========================
models/
huggingface/
*.ckpt
*.safetensors
*.bin
*.pth
*.pt
*.onnx

# =========================
# 4. 运行日志与临时输出
# =========================
logs/
temp/
outputs/
results/

# 忽略根目录及其他地方的零散图片，但【强制保留】 assets 文件夹下的演示截图！
*.png
*.jpg
*.jpeg
!assets/